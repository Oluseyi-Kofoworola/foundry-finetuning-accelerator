# =============================================================================
# VOICE AGENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values

# -----------------------------------------------------------------------------
# Branding (white-label) — derived from /config/client.config.json via
# `npm run apply:config`. Safe generic defaults are baked into the app, so
# these are optional for a first run.
# -----------------------------------------------------------------------------
BRAND_ORG_NAME=Acme Health
BRAND_SHORT_NAME=Acme
BRAND_PRODUCT_NAME=Acme Voice Agent
BRAND_ASSISTANT_NAME=Acme Virtual Assistant
BRAND_INDUSTRY=healthcare
BRAND_SUPPORT_PHONE=1-800-000-0000
BRAND_SUPPORT_URL=https://example.com/support

# -----------------------------------------------------------------------------
# OpenAI Configuration (Required for GPT Realtime API)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-api-key-here

# Model configuration - use gpt-realtime for voice
OPENAI_REALTIME_MODEL=gpt-realtime-2025-08-28

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# WebSocket configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=100

# -----------------------------------------------------------------------------
# Security & Compliance
# -----------------------------------------------------------------------------
# Enable audit logging (required for healthcare compliance)
ENABLE_AUDIT_LOGGING=true

# Audit log retention in days
AUDIT_LOG_RETENTION_DAYS=90

# Session timeout in milliseconds (30 minutes)
SESSION_TIMEOUT_MS=1800000

# Enable consent requirement
REQUIRE_CONSENT=true

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Demo Mode Settings
# -----------------------------------------------------------------------------
# Use mock tools instead of real integrations
USE_MOCK_TOOLS=true

# Enable demo mode features (sample data, relaxed validation)
DEMO_MODE=true

# Default scenario to load
DEFAULT_SCENARIO=pbm-pharmacy-assistant

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# Log file paths (relative to project root)
LOG_FILE_PATH=./logs/app.log
AUDIT_LOG_PATH=./logs/audit.log

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable voice activity detection
ENABLE_VAD=true

# Enable barge-in (interrupt while agent speaking)
ENABLE_BARGE_IN=true

# Enable text fallback mode
ENABLE_TEXT_FALLBACK=true

# Maximum conversation duration (minutes)
MAX_CONVERSATION_DURATION_MINS=30
