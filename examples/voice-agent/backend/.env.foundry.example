# ============================================================================
# Azure AI Foundry Configuration — TEMPLATE
# Copy this file to `.env.foundry` (gitignored) and fill in real values, OR
# let `deploy-foundry-upgrade.ps1` / `setup-foundry-agents.ts` generate it.
# ============================================================================

# AI Project Connection (format: <region>.api.azureml.ms;<sub-id>;<rg>;<project>)
AI_PROJECT_CONNECTION_STRING=<region>.api.azureml.ms;<your-subscription-id>;<your-resource-group>;<your-foundry-project>

# Agent IDs (filled in after you run the agent setup script)
ORCHESTRATOR_AGENT_ID=pending
PBM_AGENT_ID=pending
CONCIERGE_AGENT_ID=pending
PROVIDER_AGENT_ID=pending

# Feature Flag - Enable multi-agent (Assistants/Foundry Agents) mode
USE_FOUNDRY_AGENTS=true
