# =============================================================================
# Frontend configuration
# =============================================================================
# Copy this file to .env.local and adjust values. `npm run apply:config`
# (from the repo root) regenerates the VITE_BRAND_* values from
# /config/client.config.json.

# Backend endpoints
VITE_WS_URL=ws://localhost:8080/ws
VITE_API_URL=http://localhost:8080

# Branding (white-label) — generic defaults are baked into the app, so these
# are optional for a first run.
VITE_BRAND_ORG_NAME=Acme Health
VITE_BRAND_SHORT_NAME=Acme
VITE_BRAND_PRODUCT_NAME=Acme Voice Agent
VITE_BRAND_ASSISTANT_NAME=Acme Virtual Assistant
VITE_BRAND_COORDINATOR_LABEL=Acme Coordinator
