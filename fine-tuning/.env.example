# =============================================================================
# Fine-Tuning Labs — Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values for YOUR Azure AI Foundry
# resource. The notebooks load it with `python-dotenv`. The values below are
# derived from /config/client.config.json — run `npm run apply:config` to
# generate them automatically, or edit by hand.
#
# Required permissions on the resource:
#   • Cognitive Services OpenAI Contributor   (data plane: chat, files, fine-tune)
#   • Cognitive Services Contributor          (control plane: deploy models)
# =============================================================================

# ----- Microsoft Foundry endpoint (kind: AIServices) -----
# Preferred host for fine-tuning. Format:
#   https://<resource-name>.cognitiveservices.azure.com/
# Legacy AOAI also works:
#   https://<resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/

# API version that supports fine-tuning (SFT + DPO + tool-calling)
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ----- Base model to fine-tune -----
# Must be a FINE-TUNABLE model deployed in your resource.
# Recommended (cheap, fast, supports SFT + DPO + tool-calling):
#   gpt-4o-mini-2024-07-18
# Also valid:
#   gpt-4.1-mini-2025-04-14
#   gpt-35-turbo-0125
BASE_MODEL=gpt-4o-mini-2024-07-18

# Name of your DEPLOYED base model (the deployment name in Azure AI Foundry,
# NOT the model name). Used for "before fine-tuning" comparisons.
BASE_DEPLOYMENT=gpt-4o-mini

# ----- Generator model (used by Lab 00 to synthesize training data) -----
# Any deployed chat model works. Bigger = better quality data.
GENERATOR_DEPLOYMENT=gpt-4o-mini

# ----- ARM control plane (needed by Lab 01/02/03 to DEPLOY fine-tuned models) -----
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=rg-acme-dev
AZURE_RESOURCE_NAME=aif-acme-dev
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# ----- Foundry project name (sub-resource under the AIServices account) -----
# Optional but recommended: fine-tuning jobs show up under this project in the
# Foundry portal. Leave blank for AOAI-only resources.
AZURE_FOUNDRY_PROJECT=agents

# ----- Client identity (white-labeling) -----
# Used as a prefix for fine-tuned deployment names (e.g. acme-sft, acme-dpo,
# acme-tools) and as the tracing service-name prefix in the Foundry portal.
# Keep in sync with /config/client.config.json -> client.slug.
CLIENT_SLUG=acme
CLIENT_NAME=Acme Health

# ----- Application Insights (Foundry "Tracing" tab) -----
# Connection string for the App Insights resource attached to your Foundry
# project. Leave blank to disable tracing (labs still run).
APPLICATIONINSIGHTS_CONNECTION_STRING=
